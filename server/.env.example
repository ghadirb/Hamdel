# Copy to .env for local runs (never commit the real .env).
PORT=8080
HAMDEL_PACKAGE_NAME=com.hamdel.ai

# Shared secret the Android app sends in the X-Server-Key header. Generate any long random
# string; put the same value in the app's server.properties as HAMDEL_SERVER_API_KEY.
HAMDEL_SERVER_API_KEY=

# Cafe Bazaar: پیشخان بازار > برنامه‌تان > API پیشخان بازار > دریافت توکن جدید
BAZAAR_API_TOKEN=

# Myket: پنل توسعه‌دهندگان > برنامه‌تان > محصولات درون‌برنامه‌ای > X-Access-Token
MYKET_ACCESS_TOKEN=
