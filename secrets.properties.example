# Copy this file to "secrets.properties" (already in .gitignore, never commit the real one).
# This is the password used with encrypt_keys.py to encrypt the remote keys.txt file.
# The app downloads the encrypted keys file at startup, decrypts it with this password,
# and uses the resulting GAPGPT_API_KEY / LIARA_API_KEY values to call the AI providers.
KEYS_DECRYPT_PASSWORD=12345
